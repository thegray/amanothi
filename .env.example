# Database (individual components — DB_PASSWORD should come from Secret Manager in production)
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="password"
DB_NAME="develop"

# Google OAuth
VITE_GOOGLE_CLIENT_ID="your-google-client-id"
VITE_GOOGLE_CLIENT_SECRET="your-google-client-secret"
VITE_GOOGLE_REDIRECT_URI="http://localhost:5173/login/oauth"

# Session
VITE_SESSION_SECRET="change-this-to-a-random-string-at-least-32-characters-long"
